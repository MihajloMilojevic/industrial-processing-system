<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>IndustrialProcessingSystem.Console</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\IndustrialProcessingSystem.Core\IndustrialProcessingSystem.Core.csproj" />
    <ProjectReference Include="..\IndustrialProcessingSystem.Services\IndustrialProcessingSystem.Services.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="SystemConfig.xml">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
</Project>
